{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://diopside.invalid/schemas/tag-correction-ledger-v3.schema.json",
  "title": "Diopside tag correction ledger v3",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "correctionVersion", "generatedAt", "records", "assignmentCorrections"],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "correctionVersion": {"type": "string", "pattern": "^[0-9]{8}-v[1-9][0-9]*$"},
    "generatedAt": {"type": "string", "format": "date-time"},
    "records": {"type": "array", "items": {"$ref": "#/$defs/aliasCorrection"}},
    "assignmentCorrections": {"type": "array", "items": {"$ref": "#/$defs/assignmentCorrection"}}
  },
  "$defs": {
    "aliasCorrection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "canonical", "aliases", "evidenceType", "channelId", "reason", "source"],
      "properties": {
        "field": {"const": "people.performer"},
        "canonical": {"type": "string", "minLength": 1},
        "aliases": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "evidenceType": {"const": "channel_id_identity"},
        "channelId": {"type": "string", "pattern": "^UC[A-Za-z0-9_-]{22}$"},
        "reason": {"type": "string", "minLength": 1},
        "source": {"type": "string", "minLength": 1}
      }
    },
    "rawAssignment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["categoryId", "category", "subcategoryId", "subcategory", "tag", "reason", "source", "evidence", "confidence"],
      "properties": {
        "categoryId": {"type": "string", "minLength": 1},
        "category": {"type": "string", "minLength": 1},
        "subcategoryId": {"type": "string", "minLength": 1},
        "subcategory": {"type": "string", "minLength": 1},
        "tag": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1},
        "source": {"type": "string", "minLength": 1},
        "evidence": {"type": "string", "minLength": 1},
        "confidence": {"enum": ["high", "medium"]}
      }
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["categoryId", "subcategoryId", "tag"],
      "properties": {
        "categoryId": {"type": "string", "minLength": 1},
        "subcategoryId": {"type": "string", "minLength": 1},
        "tag": {"type": "string", "minLength": 1}
      }
    },
    "assignmentCorrection": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["operation", "videoId", "evidenceType", "assignment"],
          "properties": {
            "operation": {"const": "add"},
            "videoId": {"type": "string", "pattern": "^[A-Za-z0-9_-]{11}$"},
            "evidenceType": {"enum": ["metadata_title", "wiki_participant_list"]},
            "assignment": {"$ref": "#/$defs/rawAssignment"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["operation", "videoId", "evidenceType", "match", "assignment"],
          "properties": {
            "operation": {"const": "replace"},
            "videoId": {"type": "string", "pattern": "^[A-Za-z0-9_-]{11}$"},
            "evidenceType": {"const": "published_at_event_date"},
            "match": {"$ref": "#/$defs/match"},
            "assignment": {"$ref": "#/$defs/rawAssignment"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["operation", "videoId", "evidenceType", "match", "reviewReason"],
          "properties": {
            "operation": {"const": "review"},
            "videoId": {"type": "string", "pattern": "^[A-Za-z0-9_-]{11}$"},
            "evidenceType": {"const": "insufficient_specificity"},
            "match": {"$ref": "#/$defs/match"},
            "reviewReason": {"type": "string", "minLength": 1}
          }
        }
      ]
    }
  }
}
