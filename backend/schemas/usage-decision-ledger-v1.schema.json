{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://diopside.invalid/schemas/usage-decision-ledger-v1.schema.json",
  "title": "Diopside source usage decision ledger v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "decisionVersion", "generatedAt", "defaultDecision", "decisions"],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "decisionVersion": {"type": "string", "pattern": "^[0-9]{8}-v[1-9][0-9]*$"},
    "generatedAt": {"type": "string", "format": "date-time"},
    "defaultDecision": {"const": "exclude"},
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sourceKind", "decision", "requiredGates", "publishableFields", "evidence", "reason"],
        "properties": {
          "sourceKind": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "decision": {"enum": ["allow", "conditional", "exclude"]},
          "requiredGates": {
            "type": "array",
            "uniqueItems": true,
            "items": {"enum": ["GATE-001", "GATE-002", "GATE-003", "GATE-004", "GATE-005", "GATE-006"]}
          },
          "publishableFields": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "evidence": {"type": "array", "uniqueItems": true, "items": {"type": "string", "format": "uri"}},
          "reason": {"type": "string", "minLength": 1}
        },
        "allOf": [
          {"if": {"properties": {"decision": {"const": "conditional"}}}, "then": {"properties": {"requiredGates": {"minItems": 1}}}},
          {"if": {"properties": {"decision": {"const": "exclude"}}}, "then": {"properties": {"publishableFields": {"maxItems": 0}}}}
        ]
      }
    }
  }
}
