{
  "components": {
    "schemas": {
      "LatestContractResponse": {
        "additionalProperties": true,
        "description": "正規 `latest.json` データ。",
        "title": "LatestContractResponse",
        "type": "object"
      },
      "ReleaseContractResponse": {
        "additionalProperties": true,
        "description": "正規リリースインデックスデータ。",
        "title": "ReleaseContractResponse",
        "type": "object"
      },
      "SearchContractResponse": {
        "additionalProperties": true,
        "description": "正規検索インデックスデータ。",
        "title": "SearchContractResponse",
        "type": "object"
      },
      "TagsContractResponse": {
        "properties": {
          "alias": {
            "additionalProperties": true,
            "title": "Alias",
            "type": "object"
          },
          "index": {
            "additionalProperties": true,
            "title": "Index",
            "type": "object"
          },
          "taxonomy": {
            "additionalProperties": true,
            "title": "Taxonomy",
            "type": "object"
          }
        },
        "required": [
          "taxonomy",
          "index",
          "alias"
        ],
        "title": "TagsContractResponse",
        "type": "object"
      },
      "VideoContractResponse": {
        "additionalProperties": true,
        "description": "正規動画詳細データ。",
        "title": "VideoContractResponse",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "diopside",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/contracts/latest": {
      "get": {
        "operationId": "getLatestContract",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LatestContractResponse"
                }
              }
            },
            "description": "成功レスポンス"
          },
          "404": {
            "description": "要求された正規契約成果物が見つからない。"
          },
          "500": {
            "description": "保存済みの正規契約が不正または不整合である。"
          }
        },
        "summary": "有効な正規リリースポインターを取得する。"
      }
    },
    "/api/contracts/release/{release_id}": {
      "get": {
        "operationId": "getReleaseContract",
        "parameters": [
          {
            "in": "path",
            "name": "release_id",
            "required": true,
            "schema": {
              "title": "Release Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReleaseContractResponse"
                }
              }
            },
            "description": "成功レスポンス"
          },
          "404": {
            "description": "要求された正規契約成果物が見つからない。"
          },
          "422": {
            "description": "パスパラメーターの検証に失敗した。"
          },
          "500": {
            "description": "保存済みの正規契約が不正または不整合である。"
          }
        },
        "summary": "正規リリースインデックスを1件取得する。"
      }
    },
    "/api/contracts/releases/{release_id}/search": {
      "get": {
        "operationId": "getReleaseSearchContract",
        "parameters": [
          {
            "in": "path",
            "name": "release_id",
            "required": true,
            "schema": {
              "title": "Release Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchContractResponse"
                }
              }
            },
            "description": "成功レスポンス"
          },
          "404": {
            "description": "要求された正規契約成果物が見つからない。"
          },
          "422": {
            "description": "パスパラメーターの検証に失敗した。"
          },
          "500": {
            "description": "保存済みの正規契約が不正または不整合である。"
          }
        },
        "summary": "リリースの検索インデックスを1件取得する。"
      }
    },
    "/api/contracts/releases/{release_id}/tags": {
      "get": {
        "operationId": "getReleaseTagsContract",
        "parameters": [
          {
            "in": "path",
            "name": "release_id",
            "required": true,
            "schema": {
              "title": "Release Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TagsContractResponse"
                }
              }
            },
            "description": "成功レスポンス"
          },
          "404": {
            "description": "要求された正規契約成果物が見つからない。"
          },
          "422": {
            "description": "パスパラメーターの検証に失敗した。"
          },
          "500": {
            "description": "保存済みの正規契約が不正または不整合である。"
          }
        },
        "summary": "分類体系、タグインデックス、別名投影を取得する。"
      }
    },
    "/api/contracts/releases/{release_id}/videos/{video_id}": {
      "get": {
        "operationId": "getReleaseVideoContract",
        "parameters": [
          {
            "in": "path",
            "name": "release_id",
            "required": true,
            "schema": {
              "title": "Release Id",
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "video_id",
            "required": true,
            "schema": {
              "title": "Video Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoContractResponse"
                }
              }
            },
            "description": "成功レスポンス"
          },
          "404": {
            "description": "要求された正規契約成果物が見つからない。"
          },
          "422": {
            "description": "パスパラメーターの検証に失敗した。"
          },
          "500": {
            "description": "保存済みの正規契約が不正または不整合である。"
          }
        },
        "summary": "公開動画の詳細を1件取得する。"
      }
    },
    "/health": {
      "get": {
        "description": "プロバイダークライアントを構築せず、プロセスの準備状態を返す。",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Health Health Get",
                  "type": "object"
                }
              }
            },
            "description": "成功レスポンス"
          }
        },
        "summary": "プロセスの準備状態を取得する。",
        "tags": [
          "system"
        ]
      }
    }
  }
}
