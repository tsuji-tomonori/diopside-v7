  "info": {
    "title": "diopside",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/contracts/latest": {
      "get": {
        "operationId": "getLatestContract",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LatestContractResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "404": {
            "description": "The requested canonical contract artifact was not found."
          },
          "500": {
            "description": "The stored canonical contract is invalid or inconsistent."
          }
        },
        "summary": "Read the active canonical release pointer."
      }
    },
    "/api/contracts/release/{release_id}": {
      "get": {
        "operationId": "getReleaseContract",
